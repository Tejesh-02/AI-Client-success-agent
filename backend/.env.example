PORT=4000
# Direct Postgres URL for migrations (Supabase: Project Settings → Database → Connection string URI)
DATABASE_URL=
GROQ_API_KEY=
# Groq: use a model from console.groq.com (e.g. openai/gpt-oss-20b, openai/gpt-oss-120b, meta-llama/llama-3.3-70b-versatile)
GROQ_MODEL=openai/gpt-oss-20b
SESSION_TTL_HOURS=24
RESEND_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
JWT_ACCESS_TTL=12h
PASSWORD_SALT_ROUNDS=10